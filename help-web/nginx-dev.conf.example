# Nginx configuration for Spotto Help Portal - DEVELOPMENT
# Server: 51.38.98.84
# Domain: help.dev.spotto.pl
# Deploy path: /spotto-help-dev/
#
# Installation:
# 1. Copy to /etc/nginx/sites-available/spotto-help-dev
# 2. sudo ln -s /etc/nginx/sites-available/spotto-help-dev /etc/nginx/sites-enabled/
# 3. sudo nginx -t
# 4. sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;

    server_name help.dev.spotto.pl;

    # Root directory where help-web/dist/ is deployed via FTP
    root /spotto-help-dev;
    index index.html;

    # Enable gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/css text/javascript application/javascript application/json image/svg+xml;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Dev environment indicator (optional)
    add_header X-Environment "development" always;

    # Cache static assets (shorter cache for dev)
    location /assets/ {
        expires 1d;
        add_header Cache-Control "public";
    }

    # SPA routing - always serve index.html for non-asset requests
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Assets optimization
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1d;
        add_header Cache-Control "public";
    }

    # Access logs
    access_log /var/log/nginx/spotto-help-dev.access.log;
    error_log /var/log/nginx/spotto-help-dev.error.log;
}

