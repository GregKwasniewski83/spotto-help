# Nginx configuration for Spotto Help Portal
# Place this in /etc/nginx/sites-available/spotto-help
# Then: sudo ln -s /etc/nginx/sites-available/spotto-help /etc/nginx/sites-enabled/
# Test: sudo nginx -t
# Reload: sudo systemctl reload nginx

server {
    listen 80;
    listen [::]:80;

    # Change to your domain
    server_name help.spotto.pl;

    # Root directory where help-web/dist/ is deployed
    root /var/www/spotto-help;
    index index.html;

    # Enable gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/css text/javascript application/javascript application/json image/svg+xml;

    # Security headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    # Cache static assets (js, css, images)
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA routing - always serve index.html for non-asset requests
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Disable access logs for assets (optional)
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
    }
}

# Optional: HTTPS configuration (recommended)
# Uncomment and configure after setting up SSL certificate (e.g., Let's Encrypt)
