{
  "name": "@spotto/help-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Spotto Help Portal - Public documentation website",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build": "npm run build:content && npm run build:search && tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "build:search": "tsx scripts/build-search.ts",
    "preview": "vite preview",
    "watch:content": "nodemon --watch ../docs --ext md --exec 'npm run build:content'",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "fuse.js": "^7.0.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.9.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^7.1.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fs-extra": "^11.2.0",
    "glob": "^11.0.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.3",
    "vite-plugin-static-copy": "^2.1.0"
  }
}
